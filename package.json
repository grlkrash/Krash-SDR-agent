{
  "name": "krash-sdr-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:web": "node dist/scripts/validateEnv.js && node dist/scripts/waitForDatabase.js && npx prisma migrate deploy && node dist/server.js",
    "start:cron": "node dist/scripts/validateEnv.js && node dist/scripts/waitForDatabase.js && node dist/scripts/cronTick.js",
    "cron:one": "node dist/scripts/runCron.js",
    "kb:reindex": "tsx src/scripts/reindexKB.ts",
    "exclusions:import": "tsx src/scripts/importExclusions.ts",
    "exclusions:sync-directory": "tsx src/scripts/syncDirectoryExclusions.ts",
    "migrate": "prisma migrate dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "playwright install chromium"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@hubspot/api-client": "^13.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^172.0.0",
    "jsonwebtoken": "^9.0.3",
    "libphonenumber-js": "^1.13.3",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
